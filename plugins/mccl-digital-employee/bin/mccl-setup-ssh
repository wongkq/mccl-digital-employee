#!/usr/bin/env bash
# 新机器一次性配置：让本机能免密登录 Node 0。
#
# 为什么只配 Node 0 一台：
#   工具包的规则是"一律经 $MCCL_NODE0_IP 跳转"（references/mccl-remote-ops.md 第5节）。
#   本机 → Node 0 需要免密；Node 0 → Node 1/2/3 是节点之间的事，mpirun 跨节点本来就
#   依赖它、早已配好。所以换机器只需配这一条链路。
#
# 密码只在 ssh-copy-id 时交互输入一次，不存盘、不进环境变量、不进日志。
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "错误：不在git仓库里。请在MCCL仓库根目录运行。" >&2; exit 1; }
ENV_FILE="$REPO_ROOT/mccl-env.sh"
[ -f "$ENV_FILE" ] || {
  echo "错误：找不到 $ENV_FILE" >&2
  echo "请先： cp <插件>/mccl-env.sh.example $ENV_FILE  然后填入真实值" >&2; exit 1; }
# shellcheck disable=SC1090
source "$ENV_FILE"

: "${MCCL_NODES:?mccl-env.sh 里缺 MCCL_NODES}"
: "${MCCL_NODE0_IP:?mccl-env.sh 里缺 MCCL_NODE0_IP（应由 MCCL_NODES 派生）}"
: "${MCCL_NNODES:?mccl-env.sh 里缺 MCCL_NNODES（应由 MCCL_NODES 派生）}"

# 除编译节点外的其余节点（单节点时为空）
PEERS="$(echo "$MCCL_NODES" | cut -d' ' -f2-)"
[ "$PEERS" = "$MCCL_NODES" ] && PEERS=""   # 只有一个节点时 cut -f2- 会原样返回

echo "拓扑：$MCCL_NNODES 个节点，编译节点 $MCCL_NODE0_IP"
case "$MCCL_NNODES" in
  1) echo "     单节点模式——跨节点链路无需配置，跳过第2步" ;;
  4|8) : ;;
  *) echo "     警告：MCCL 只硬编码了 OAM32(4节点) 和 OAM64(8节点) 两种拓扑。" >&2
     echo "     $MCCL_NNODES 节点不是受支持的拓扑，对称内存路径不会启用。" >&2
     echo "     SSH 链路仍会照配，但跑测试时 agent 会拒绝执行。" >&2 ;;
esac

SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new"
fail=0

echo "== 1. 本机 → Node 0 ($MCCL_NODE0_IP) 免密 =="
if ssh $SSH_OPTS "root@$MCCL_NODE0_IP" true 2>/dev/null; then
  echo "   已通，无需配置"
else
  # 先分清"连不上"和"连得上但没配密钥"。
  # 不做这个区分的话，主机不可达时会一头扎进 ssh-copy-id 然后阻塞等密码——
  # 交互式挂起在agent环境里等于卡死。
  probe="$(ssh -o BatchMode=yes -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new \
           "root@$MCCL_NODE0_IP" true 2>&1)"
  case "$probe" in
    *"Permission denied"*)
      : ;;  # 主机可达、SSH服务在、只是没有密钥 → 正是 ssh-copy-id 要解决的
    *)
      echo "   连不上 $MCCL_NODE0_IP，不是密钥的问题：" >&2
      echo "     $probe" >&2
      echo "   先确认IP对不对（mccl-env.sh 的 MCCL_NODES）、网络通不通、SSH服务在不在。" >&2
      echo "   主机都不可达时配密钥没有意义，这里直接停，不进入密码提示。" >&2
      exit 1 ;;
  esac
  echo "   主机可达但未配密钥。"
  # 公钥不存在就先生成（非交互，安全）——这样等下不管谁跑 ssh-copy-id 都有 key 可用
  if [ ! -f "$HOME/.ssh/id_rsa.pub" ] && [ ! -f "$HOME/.ssh/id_ed25519.pub" ]; then
    echo "   本机没有ssh公钥，生成中（无密码短语）..."
    ssh-keygen -t ed25519 -N '' -f "$HOME/.ssh/id_ed25519" -q || { echo "   ssh-keygen失败"; exit 1; }
  fi
  # ssh-copy-id 会交互式弹密码。分两种情况：
  #   - 有交互终端（你自己在终端里跑）：直接跑，输一次密码
  #   - 没有交互终端（AI通过Bash工具在跑）：弹密码会卡死到超时——不硬闯，
  #     把现成命令交还给你，你手动跑这一条即可，其余都不用管
  if [ -t 0 ]; then
    echo "   接下来会提示输入 root@$MCCL_NODE0_IP 的密码（只用这一次，不存盘）："
    ssh-copy-id -o StrictHostKeyChecking=accept-new "root@$MCCL_NODE0_IP" || {
      echo "   ssh-copy-id 失败" >&2; exit 1; }
    ssh $SSH_OPTS "root@$MCCL_NODE0_IP" true 2>/dev/null \
      && echo "   配置成功" || { echo "   配置后仍不通" >&2; exit 1; }
  else
    echo "   检测到没有交互终端（多半是AI在替你跑本脚本）。" >&2
    echo "   配密钥要输一次密码，这一步只能你自己来。请在你的终端里手动跑这一条：" >&2
    echo "" >&2
    echo "       ssh-copy-id -o StrictHostKeyChecking=accept-new root@$MCCL_NODE0_IP" >&2
    echo "" >&2
    echo "   输一次密码即可（不存盘）。跑完再让AI重新执行本脚本，它就会跳过这步继续往下检查。" >&2
    exit 2   # 退出码2 = 需要人工输密码，区别于退出码1的真失败
  fi
fi

if [ -z "$PEERS" ]; then
  echo "== 2. 跨节点免密：单节点拓扑，无需检查 =="
else
  echo "== 2. 编译节点 → 其余节点免密（工具包依赖，本机配不了，只检查）=="
  for ip in $PEERS; do
    if ssh $SSH_OPTS "root@$MCCL_NODE0_IP" "ssh $SSH_OPTS root@$ip true" 2>/dev/null; then
      echo "   $MCCL_NODE0_IP → $ip  通"
    else
      echo "   $MCCL_NODE0_IP → $ip  不通 ← 分发libmccl.so和跨节点mpirun都会失败" >&2
      fail=1
    fi
  done
fi

if [ -n "$MCCL_CONTAINER" ]; then
  echo "== 3. 容器 ($MCCL_CONTAINER) 可达 =="
  if ssh $SSH_OPTS "root@$MCCL_NODE0_IP" "docker exec $MCCL_CONTAINER true" 2>/dev/null; then
    echo "   通"
  else
    echo "   不通 ← 编译会失败。检查容器名是否为 $MCCL_CONTAINER、是否在运行" >&2
    fail=1
  fi
else
  echo "== 3. 无容器模式（MCCL_CONTAINER 为空）：跳过容器检查 =="
  echo "   编译直接在宿主机跑，请确认编译节点已装好 MACA SDK 且 mxcc 在登录shell的PATH里"
fi

echo
if [ "$fail" -eq 0 ]; then
  echo "全部就绪。可以跑 /mccl-run 了。"
else
  echo "有不通的链路（见上）。Node 0 → Node 1/2/3 需要在 Node 0 上配，不在本机。" >&2
fi
exit "$fail"
