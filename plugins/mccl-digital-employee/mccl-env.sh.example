#!/usr/bin/env bash
# 拷贝为 mccl-env.sh 并填入真实值。mccl-env.sh 不入库（见 .gitignore）。
# 所有 agent 从此文件取环境值，不得硬编码。

# 换机器/换IP时：改完下面的IP，跑一次
#   bash <插件>/bin/mccl-setup-ssh
# 它只需配"本机 → NODE0"一条链路（工具包一律经NODE0跳转），
# 并检查 NODE0 → NODE1/2/3 和容器是否可达。密码只在交互时输入一次，不存盘。

# --- 计算节点 ---
# 节点列表，空格分隔。第一个必须是编译节点（容器宿主，即下面派生出的
# MCCL_NODE0_IP）。除第一个之外的节点只接受 scp 的 libmccl.so，
# 禁止在其上编译或修改源码。
#
# 只支持三档节点数，agent开工时会据此校验拓扑合法性：
#   1个IP → 单节点冒烟（容器内 --mca plm isolated，不测跨节点对称内存路径）
#   4个IP → OAM32（现有完整流程，32卡）
#   8个IP → OAM64（同OAM32形态，-np 64）
# 其余节点数：MCCL只硬编码了OAM32/OAM64两种拓扑，CliqueManager::IsSupported()
# 的OAM32分支不匹配2/3/5...节点，对称内存路径不会启用，会静默fallback到
# Ring/Tree——测出来的东西不是你以为在测的东西。agent遇到其余节点数应停止并上报。
export MCCL_NODES="<node0-ip> <node1-ip> <node2-ip> <node3-ip>"
# =8 是对称内存/FC kernel的硬前提：nodeSize=8由PCIe Switch硬件结构决定、代码里
# 直接硬编码（见references/mccl-domain.md第14行）。填其他值（如2）：单节点时能跑
# 基础AllReduce冒烟，但对称内存/FC kernel路径不会启用，agent会在报告里声明未覆盖；
# 多节点（4/8）配非8卡会被agent判为不受支持的拓扑，停止并上报，不跑mpirun。
export MCCL_GPUS_PER_NODE=8

# 以下四个由上面两行派生，不要手改——手改成写死的值会导致这里和
# $MCCL_NODES 对不上（tests/check.sh 不变式12会查）
export MCCL_NODE0_IP="$(echo $MCCL_NODES | cut -d' ' -f1)"
export MCCL_NNODES="$(echo $MCCL_NODES | wc -w)"
export MCCL_NP="$(( MCCL_NNODES * MCCL_GPUS_PER_NODE ))"
export MCCL_HOST_SPEC="$(for ip in $MCCL_NODES; do printf '%s:%s,' "$ip" "$MCCL_GPUS_PER_NODE"; done | sed 's/,$//')"

# Node 0 上的编译容器名
# 所有 ssh/scp 必须带这组选项。BatchMode=yes 让"密钥没配好"变成立刻失败而不是
# 弹密码提示——agent 的 Bash 调用等不到人输密码，弹提示等于卡死。
# 密钥没配好时应该跑 bin/mccl-setup-ssh，不是让 agent 挂在那里。
export MCCL_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new"

# 留空=无容器模式，编译直接在宿主机（$MCCL_NODE0_IP）跑，不套 docker exec；
# 此时需宿主机装好完整 MACA SDK 且工具链（mxcc、cu-bridge）在登录 shell 的 PATH 里。
# 填容器名（如 "zb"）=容器模式，远程命令套一层 docker exec $MCCL_CONTAINER。
# 判断方式：[ -n "$MCCL_CONTAINER" ] 为真=容器模式。不要手工派生、不要给它设默认值。
export MCCL_CONTAINER="<container-name>"

# --- 编译 ---
# 必须指向含正确 mcMemFabricHandle_t 定义的 MACA 安装。另一个常见路径下的定义
# 是旧版 stub，结构体尺寸不同，会导致跨节点对称内存句柄异常。
# 详见 references/mccl-build-pitfalls.md
export MCCL_MACA_PATH="<maca-path>"

# 厂商标准 MACA 安装路径（MetaX SDK 的默认安装位置）。它的 mcMemFabricHandle_t 是
# 旧版 stub，**不能拿来编译**；但两处仍要用到它：全量重编时先从它派生出编译器与
# cu-bridge 工具链路径，以及 mxgpu_llvm/bin 的符号链接源。
# 详见 references/mccl-build-pitfalls.md 第3、4条。
export MCCL_VENDOR_MACA_PATH="<vendor-maca-path>"

# mpirun 实际加载 libmccl.so 的库目录，也是跨节点分发（4 个节点）的落点。
# 必须与 MCCL_LD_LIBRARY_PATH 的库目录部分是同一个目录——开发分发到这里、
# 测试对这里做 md5 核对，两边指同一处才对得上。
export MCCL_MACA_LIB_DIR="${MCCL_MACA_PATH}/lib"

# agent 在远程的可写范围边界。此目录之外一律禁止修改。
export MCCL_REMOTE_WORKDIR="<remote-workdir>"

# 本地 MCCL 源码仓库路径（你自己填，每台机器不同）
export MCCL_LOCAL_SRC="<local-repo-path>"

# 编译节点上的源码目录 = 工作目录 + 源码目录名。换环境时通常只需改目录名，
# WORKDIR 变了这里自动跟上。若你的源码不在 WORKDIR 下面，也可以整条写死成绝对路径。
export MCCL_REMOTE_SRC="${MCCL_REMOTE_WORKDIR}/<repo-dir-name>"

# --- 测试 ---
export MCCL_MPIRUN="<mpirun-path>"
export MCCL_PERF_BIN_ASYM="<asymmetric-perf-binary>"  # 场景A：不带 -R
export MCCL_PERF_BIN_SYM="<symmetric-perf-binary>"    # 场景B：带 -R 2
export MCCL_LD_LIBRARY_PATH="${MCCL_MACA_LIB_DIR}:<ompi-lib-path>"
export MCCL_TCP_IF_INCLUDE="<cidr>"
